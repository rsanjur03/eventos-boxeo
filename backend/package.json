{
  "name": "my-sonicjs-app",
  "version": "0.1.0",
  "private": true,
  "description": "A SonicJS headless CMS application",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sonicjs-cms/core": "2.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^20.19.1",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.65.0",
    "zod": "^3.25.67"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}