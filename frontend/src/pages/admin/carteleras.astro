---
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Fetch fights
let fights = [];
try {
  const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
  const res = await fetch(`${apiUrl}/api/content?collection=fight`);
  if (res.ok) {
    const data = await res.json();
    fights = data.data || [];
  }
} catch (error) {
  console.error('Error fetching fights:', error);
}
---

<AdminLayout title="Carteleras (Peleas)">
  
  <div class="mb-8 flex justify-between items-center">
    <p class="text-gray-600">Arma las carteleras para los eventos y registra los resultados de las peleas.</p>
    <button class="bg-[var(--color-primary)] text-black font-bold px-6 py-2 rounded-lg shadow hover:bg-yellow-400 transition">
      + Nueva Pelea
    </button>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100">
      <h3 class="text-lg font-bold text-gray-800">Historial de Peleas</h3>
    </div>
    
    {fights.length === 0 ? (
      <div class="p-8 text-center text-gray-500">
        No hay peleas registradas. Haz clic en "Nueva Pelea" para agregar una al historial.
      </div>
    ) : (
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase">
          <tr>
            <th class="px-6 py-3">Pelea</th>
            <th class="px-6 py-3">Peso</th>
            <th class="px-6 py-3">Asaltos</th>
            <th class="px-6 py-3">Resultado</th>
            <th class="px-6 py-3 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {fights.map((f: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-bold text-gray-800">{f.data.title}</td>
              <td class="px-6 py-4 text-gray-600">{f.data.weightClass}</td>
              <td class="px-6 py-4 text-gray-600">{f.data.rounds || '-'}</td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 bg-gray-100 text-gray-800 rounded font-semibold text-xs">
                  {f.data.result || 'Pendiente'}
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <button class="text-blue-600 hover:underline">Editar</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

</AdminLayout>
