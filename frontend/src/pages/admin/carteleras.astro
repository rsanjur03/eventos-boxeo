---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Fetch events
let events = [];
try {
  const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
  const res = await fetch(`${apiUrl}/api/content?collection=event`);
  if (res.ok) {
    const data = await res.json();
    events = data.data || [];
  }
} catch (error) {
  console.error('Error fetching events:', error);
}

// Helper to format date
const formatDate = (dateString: string) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString('es-PA', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
};
---

<AdminLayout title="Carteleras (Eventos)">
  
  <div class="mb-8 flex justify-between items-center">
    <p class="text-gray-600">Selecciona un evento para administrar sus peleas (matchmaking) y registrar resultados.</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100">
      <h3 class="text-lg font-bold text-gray-800">Todos los Eventos</h3>
    </div>
    
    {events.length === 0 ? (
      <div class="p-8 text-center text-gray-500">
        No hay eventos registrados.
      </div>
    ) : (
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase">
          <tr>
            <th class="px-6 py-3">Nombre del Evento</th>
            <th class="px-6 py-3">Fecha</th>
            <th class="px-6 py-3">Organizador</th>
            <th class="px-6 py-3 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {events.map((e: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-bold text-gray-800">{e.data.title}</td>
              <td class="px-6 py-4 text-gray-600">{formatDate(e.data.date)}</td>
              <td class="px-6 py-4">
                {e.data.comiboxOrganized !== false ? (
                  <span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded font-bold text-xs">COMIBOX</span>
                ) : (
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded font-bold text-xs">Terceros (Fiscalizado)</span>
                )}
              </td>
              <td class="px-6 py-4 text-right">
                <a href={`/admin/eventos/${e.slug}`} class="text-blue-600 hover:underline font-bold">Ver Peleas &rarr;</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

</AdminLayout>
