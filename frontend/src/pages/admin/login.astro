---
import '../../styles/global.css';

const ALLOWED_EMAILS = ['ricardosanjur@gmail.com', 'eysbel@gmail.com'];
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD || 'Comibox2026';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const email = String(data.get('email') || '').trim();
    const password = String(data.get('password') || '');

    if (!ALLOWED_EMAILS.includes(email.toLowerCase())) {
      error = 'Correo electrónico no autorizado.';
    } else if (password !== ADMIN_PASSWORD) {
      error = 'Contraseña incorrecta.';
    } else {
      // Todo correcto, crear cookie de sesión segura
      Astro.cookies.set('admin_session', 'authenticated', {
        path: '/admin',
        httpOnly: true,
        secure: import.meta.env.PROD,
        sameSite: 'lax',
        maxAge: 60 * 60 * 24 * 7 // 1 semana
      });
      // Redirigir al dashboard
      return Astro.redirect('/admin');
    }
  } catch (e) {
    error = 'Error al procesar el inicio de sesión.';
  }
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso Restringido | COMIBOX</title>
  </head>
  <body class="bg-gray-100 min-h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-black text-gray-900 mb-2">COMIBOX</h1>
        <p class="text-gray-500">Panel de Administración Restringido</p>
      </div>

      {error && (
        <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm font-semibold mb-6 text-center">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Correo Electrónico</label>
          <input 
            type="email" 
            name="email" 
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 transition"
            placeholder="ejemplo@gmail.com"
          />
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Contraseña Maestra</label>
          <input 
            type="password" 
            name="password" 
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 transition"
            placeholder="••••••••"
          />
        </div>

        <button 
          type="submit" 
          class="w-full bg-[#FFD700] hover:bg-yellow-500 text-black font-bold py-3 rounded-lg shadow transition mt-4">
          Iniciar Sesión
        </button>
      </form>

      <p class="text-xs text-gray-400 text-center mt-6">
        Acceso exclusivo para directivos autorizados. Todos los intentos de acceso son registrados.
      </p>
    </div>
  </body>
</html>

