---
import AdminLayout from '../../layouts/AdminLayout.astro';

const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
let actionMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title');
    const alias = data.get('alias');
    const nationality = data.get('nationality');
    const province = data.get('province');
    const height = data.get('height');
    const weight = data.get('weight');
    const stance = data.get('stance');
    const dob = data.get('dob');
    const birthPlace = data.get('birthPlace');
    const residence = data.get('residence');
    const trainer = data.get('trainer');
    const manager = data.get('manager');

    const wins = Number(data.get('wins') || 0);
    const losses = Number(data.get('losses') || 0);
    const draws = Number(data.get('draws') || 0);
    const kos = Number(data.get('kos') || 0);
    const kos_lost = Number(data.get('kos_lost') || 0);
    
    const boxerData = {
      title, alias, nationality, province, height, weight, stance, dob, birthPlace, residence, trainer, manager,
      wins, losses, draws, kos, kos_lost
    };

    const res = await fetch(`${apiUrl}/api/unsecured/content/boxer`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(boxerData)
    });

    if (res.ok) {
      actionMessage = 'Boxeador creado exitosamente.';
    } else {
      let errorText = await res.text();
      try {
        const errorJson = JSON.parse(errorText);
        errorText = errorJson.message || errorJson.error || errorText;
      } catch (e) {}
      actionMessage = `Error al crear el boxeador: ${res.status} - ${errorText}`;
    }
  } catch (error: any) {
    console.error(error);
    actionMessage = `Error de red al procesar el formulario: ${error.message}`;
  }
}

// Fetch boxers
let boxers = [];
try {
  const res = await fetch(`${apiUrl}/api/content?collection=boxer`);
  if (res.ok) {
    const data = await res.json();
    boxers = data.data || [];
  }
} catch (error) {
  console.error('Error fetching boxers:', error);
}
---

<AdminLayout title="Gestión de Boxeadores">
  
  <div class="mb-8 flex justify-between items-center">
    <p class="text-gray-600">Administra el roster de boxeadores registrados.</p>
  </div>

  {actionMessage && (
    <div class="mb-6 bg-green-50 text-green-700 p-4 rounded-lg font-bold">
      {actionMessage}
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    {/* Lista */}
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-6 border-b border-gray-100">
        <h3 class="text-lg font-bold text-gray-800">Directorio de Boxeadores</h3>
      </div>
      
      {boxers.length === 0 ? (
        <div class="p-8 text-center text-gray-500">No hay boxeadores registrados.</div>
      ) : (
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-gray-500 uppercase">
            <tr>
              <th class="px-6 py-3">Nombre</th>
              <th class="px-6 py-3">Alias</th>
              <th class="px-6 py-3">Nacionalidad</th>
              <th class="px-6 py-3">Récord</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {boxers.map((b: any) => (
              <tr class="hover:bg-gray-50 cursor-pointer" onclick={`window.location.href='/admin/boxeadores/${b.id}'`}>
                <td class="px-6 py-4 font-bold text-gray-800 text-blue-600 hover:underline">{b.data.title}</td>
                <td class="px-6 py-4 text-gray-600">{b.data.alias || '-'}</td>
                <td class="px-6 py-4 text-gray-600">{b.data.nationality || '-'}</td>
                <td class="px-6 py-4 font-semibold text-gray-700">
                  {b.data.wins || 0}-{b.data.losses || 0}-{b.data.draws || 0} ({b.data.kos || 0} KO)
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    {/* Formulario */}
    <div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sticky top-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Registrar Nuevo Boxeador</h3>
        <form method="POST" class="space-y-4">
          
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre Completo</label>
            <input type="text" name="title" required class="w-full border border-gray-300 rounded p-2" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Apodo (Alias)</label>
            <input type="text" name="alias" class="w-full border border-gray-300 rounded p-2" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Nacionalidad</label>
              <input type="text" name="nationality" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Provincia</label>
              <input type="text" name="province" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Guardia</label>
              <select name="stance" class="w-full border border-gray-300 rounded p-2">
                <option value="Orthodox">Diestro (Orthodox)</option>
                <option value="Southpaw">Zurdo (Southpaw)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Fecha de Nacimiento</label>
              <input type="date" name="dob" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Lugar de Nacimiento</label>
              <input type="text" name="birthPlace" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Residencia</label>
              <input type="text" name="residence" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Estatura</label>
              <input type="text" name="height" placeholder="Ej: 5'8&quot;" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Peso Natural</label>
              <input type="text" name="weight" placeholder="Ej: 135 lbs" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Entrenador</label>
              <input type="text" name="trainer" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Manejador</label>
              <input type="text" name="manager" class="w-full border border-gray-300 rounded p-2" />
            </div>
          </div>

          <hr class="my-4" />
          <h4 class="font-bold text-gray-800">Récord Actual</h4>
          
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-sm text-gray-600 mb-1">Victorias</label>
              <input type="number" name="wins" min="0" value="0" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">Derrotas</label>
              <input type="number" name="losses" min="0" value="0" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">Empates</label>
              <input type="number" name="draws" min="0" value="0" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">KOs (Ganados)</label>
              <input type="number" name="kos" min="0" value="0" class="w-full border border-gray-300 rounded p-2" />
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">KOs (Perdidos)</label>
              <input type="number" name="kos_lost" min="0" value="0" class="w-full border border-gray-300 rounded p-2" />
            </div>
          </div>

          <p class="text-xs text-gray-500 mt-2">
            Nota: La subida de foto directa está en desarrollo debido a la infraestructura en la nube. Por ahora, las fotos se suben directamente en SonicJS.
          </p>

          <button type="submit" class="w-full bg-[var(--color-primary)] text-black font-bold py-3 rounded mt-4 hover:bg-yellow-400 transition">
            Crear Boxeador
          </button>
        </form>
      </div>
    </div>

  </div>
</AdminLayout>
