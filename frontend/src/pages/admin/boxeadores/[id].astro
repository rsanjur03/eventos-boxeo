---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const { id } = Astro.params;
const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
let actionMessage = '';

// Fetch boxer details
let boxer = null;
try {
  const res = await fetch(`${apiUrl}/api/content/${id}`);
  if (res.ok) {
    const data = await res.json();
    boxer = data.data || data; // handle if wrapped in {data: ...}
  }
} catch (e) {
  console.error('Error fetching boxer:', e);
}

if (!boxer) {
  return Astro.redirect('/admin/boxeadores');
}

// Ensure bouts array exists
if (!boxer.data.bouts) boxer.data.bouts = [];

let calculatedAge = '-';
if (boxer.data.dob) {
  const birthDate = new Date(boxer.data.dob);
  const today = new Date();
  let age = today.getFullYear() - birthDate.getFullYear();
  const m = today.getMonth() - birthDate.getMonth();
  if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
    age--;
  }
  calculatedAge = age.toString() + ' años';
}

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const type = data.get('actionType');

    if (type === 'addBout') {
      const newBout = {
        date: data.get('date'),
        opponent: data.get('opponent'),
        result: data.get('result'),
        method: data.get('method'),
        rounds: data.get('rounds'),
        location: data.get('location')
      };

      const bouts = [...boxer.data.bouts, newBout];
      
      // Calculate new record
      let wins = Number(boxer.data.wins || 0);
      let losses = Number(boxer.data.losses || 0);
      let draws = Number(boxer.data.draws || 0);
      let kos = Number(boxer.data.kos || 0);
      let kos_lost = Number(boxer.data.kos_lost || 0);
      
      if (newBout.result === 'W') {
        wins += 1;
        if (newBout.method === 'KO' || newBout.method === 'TKO') {
          kos += 1;
        }
      } else if (newBout.result === 'L') {
        losses += 1;
        if (newBout.method === 'KO' || newBout.method === 'TKO') {
          kos_lost += 1;
        }
      } else if (newBout.result === 'D') {
        draws += 1;
      }

      const res = await fetch(`${apiUrl}/api/unsecured/content/boxer/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bouts, wins, losses, draws, kos, kos_lost })
      });

      if (res.ok) {
        actionMessage = 'Historial actualizado correctamente.';
        // Refresh data
        boxer.data.bouts = bouts;
        boxer.data.wins = wins;
        boxer.data.losses = losses;
        boxer.data.draws = draws;
        boxer.data.kos = kos;
        boxer.data.kos_lost = kos_lost;
      } else {
        let errText = await res.text();
        actionMessage = `Error al guardar el historial: ${errText}`;
      }
    } else if (type === 'editInfo') {
      const updatedBoxer = {
        title: data.get('title'),
        alias: data.get('alias'),
        nationality: data.get('nationality'),
        province: data.get('province'),
        dob: data.get('dob'),
        birthPlace: data.get('birthPlace'),
        residence: data.get('residence'),
        height: data.get('height'),
        weight: data.get('weight'),
        stance: data.get('stance'),
        trainer: data.get('trainer'),
        manager: data.get('manager'),
        wins: Number(data.get('wins') || 0),
        losses: Number(data.get('losses') || 0),
        draws: Number(data.get('draws') || 0),
        kos: Number(data.get('kos') || 0),
        kos_lost: Number(data.get('kos_lost') || 0),
      };
      const res = await fetch(`${apiUrl}/api/unsecured/content/boxer/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updatedBoxer)
      });
      if (res.ok) {
        actionMessage = 'Información actualizada correctamente.';
        Object.assign(boxer.data, updatedBoxer);
      } else {
        let errText = await res.text();
        actionMessage = `Error al actualizar la información: ${errText}`;
      }
    }
  } catch (error) {
    console.error(error);
    actionMessage = 'Error al procesar el formulario.';
  }
}

---

<AdminLayout title={`Perfil de ${boxer.data.title}`}>
  
  <div class="mb-6 flex justify-between items-center">
    <a href="/admin/boxeadores" class="text-blue-600 hover:underline font-semibold">&larr; Volver al Roster</a>
  </div>

  {actionMessage && (
    <div class="mb-6 bg-green-50 text-green-700 p-4 rounded-lg font-bold">
      {actionMessage}
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    {/* Resumen */}
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center">
        <div class="w-32 h-32 bg-gray-200 rounded-full mx-auto mb-4 overflow-hidden border-4 border-gray-100">
          {boxer.data.imageUrl ? (
            <img src={boxer.data.imageUrl} alt={boxer.data.title} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-4xl text-gray-400">🥊</div>
          )}
        </div>
        <h2 class="text-2xl font-black text-gray-800">{boxer.data.title}</h2>
        <p class="text-gray-500 font-semibold">{boxer.data.alias || 'Sin apodo'}</p>
        
        <div class="flex justify-center mt-4 space-x-4">
          <div class="text-center">
            <span class="block text-2xl font-bold text-green-600">{boxer.data.wins || 0}</span>
            <span class="text-xs text-gray-500 font-bold uppercase">Victorias</span>
            <span class="block text-xs font-bold text-green-700 mt-1">{boxer.data.kos || 0} KOs</span>
          </div>
          <div class="text-center">
            <span class="block text-2xl font-bold text-red-600">{boxer.data.losses || 0}</span>
            <span class="text-xs text-gray-500 font-bold uppercase">Derrotas</span>
            <span class="block text-xs font-bold text-red-700 mt-1">{boxer.data.kos_lost || 0} KOs</span>
          </div>
          <div class="text-center">
            <span class="block text-2xl font-bold text-gray-600">{boxer.data.draws || 0}</span>
            <span class="text-xs text-gray-500 font-bold uppercase">Empates</span>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6" id="info-view">
        <div class="flex justify-between items-center border-b pb-2 mb-4">
          <h3 class="font-bold text-gray-800">Información</h3>
          <button onclick="document.getElementById('info-view').classList.add('hidden'); document.getElementById('info-edit').classList.remove('hidden');" class="text-blue-600 hover:underline text-xs font-bold">Editar</button>
        </div>
        <ul class="space-y-3 text-sm">
          <li class="flex justify-between"><span class="text-gray-500">Nacionalidad:</span> <span class="font-semibold text-gray-800">{boxer.data.nationality || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Provincia:</span> <span class="font-semibold text-gray-800">{boxer.data.province || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Fecha Nacimiento:</span> <span class="font-semibold text-gray-800">{boxer.data.dob || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Edad:</span> <span class="font-semibold text-gray-800">{calculatedAge}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Lugar Nacimiento:</span> <span class="font-semibold text-gray-800">{boxer.data.birthPlace || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Residencia:</span> <span class="font-semibold text-gray-800">{boxer.data.residence || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Estatura:</span> <span class="font-semibold text-gray-800">{boxer.data.height || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Peso:</span> <span class="font-semibold text-gray-800">{boxer.data.weight || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Guardia:</span> <span class="font-semibold text-gray-800">{boxer.data.stance || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Entrenador:</span> <span class="font-semibold text-gray-800">{boxer.data.trainer || '-'}</span></li>
          <li class="flex justify-between"><span class="text-gray-500">Manejador:</span> <span class="font-semibold text-gray-800">{boxer.data.manager || '-'}</span></li>
        </ul>
      </div>

      <div class="bg-gray-50 rounded-xl shadow-sm border border-blue-200 p-6 hidden" id="info-edit">
        <div class="flex justify-between items-center border-b border-gray-200 pb-2 mb-4">
          <h3 class="font-bold text-gray-800">Editar Información</h3>
          <button onclick="document.getElementById('info-edit').classList.add('hidden'); document.getElementById('info-view').classList.remove('hidden');" class="text-red-600 hover:underline text-xs font-bold">Cancelar</button>
        </div>
        <form method="POST" class="space-y-3 text-sm">
          <input type="hidden" name="actionType" value="editInfo" />
          
          <div class="grid grid-cols-2 gap-2">
            <div><label class="text-xs text-gray-500 font-bold block mb-1">Victorias</label><input type="number" name="wins" value={boxer.data.wins || 0} class="w-full border rounded p-1" /></div>
            <div><label class="text-xs text-gray-500 font-bold block mb-1">KOs (Victorias)</label><input type="number" name="kos" value={boxer.data.kos || 0} class="w-full border rounded p-1" /></div>
            <div><label class="text-xs text-gray-500 font-bold block mb-1">Derrotas</label><input type="number" name="losses" value={boxer.data.losses || 0} class="w-full border rounded p-1" /></div>
            <div><label class="text-xs text-gray-500 font-bold block mb-1">KOs (Derrotas)</label><input type="number" name="kos_lost" value={boxer.data.kos_lost || 0} class="w-full border rounded p-1" /></div>
            <div><label class="text-xs text-gray-500 font-bold block mb-1">Empates</label><input type="number" name="draws" value={boxer.data.draws || 0} class="w-full border rounded p-1" /></div>
          </div>
          <hr class="my-2 border-gray-200" />
          
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Nombre</label><input type="text" name="title" value={boxer.data.title} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Apodo</label><input type="text" name="alias" value={boxer.data.alias} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Nacionalidad</label><input type="text" name="nationality" value={boxer.data.nationality} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Provincia</label><input type="text" name="province" value={boxer.data.province} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Fecha Nac.</label><input type="date" name="dob" value={boxer.data.dob} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Lugar Nac.</label><input type="text" name="birthPlace" value={boxer.data.birthPlace} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Residencia</label><input type="text" name="residence" value={boxer.data.residence} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Estatura</label><input type="text" name="height" value={boxer.data.height} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Peso (Lbs/Kg)</label><input type="text" name="weight" value={boxer.data.weight} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Guardia</label><input type="text" name="stance" value={boxer.data.stance} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Entrenador</label><input type="text" name="trainer" value={boxer.data.trainer} class="w-full border rounded p-1" /></div>
          <div><label class="text-xs text-gray-500 font-bold block mb-1">Manejador</label><input type="text" name="manager" value={boxer.data.manager} class="w-full border rounded p-1" /></div>
          
          <div class="mt-4"><button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded">Guardar Cambios</button></div>
        </form>
      </div>
    </div>

    {/* Historial de Peleas */}
    <div class="lg:col-span-2 space-y-6">
      
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Añadir Pelea al Historial</h3>
        <form method="POST" class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <input type="hidden" name="actionType" value="addBout" />
          
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Fecha</label>
            <input type="date" name="date" required class="w-full border border-gray-300 rounded p-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Oponente</label>
            <input type="text" name="opponent" required class="w-full border border-gray-300 rounded p-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Locación</label>
            <input type="text" name="location" class="w-full border border-gray-300 rounded p-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Resultado</label>
            <select name="result" class="w-full border border-gray-300 rounded p-2 text-sm">
              <option value="W">Victoria (W)</option>
              <option value="L">Derrota (L)</option>
              <option value="D">Empate (D)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Método</label>
            <select name="method" class="w-full border border-gray-300 rounded p-2 text-sm">
              <option value="UD">Decisión Unánime (UD)</option>
              <option value="SD">Decisión Dividida (SD)</option>
              <option value="MD">Decisión Mayoritaria (MD)</option>
              <option value="KO">Nocaut (KO)</option>
              <option value="TKO">Nocaut Técnico (TKO)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1">Rounds</label>
            <input type="text" name="rounds" placeholder="Ej. 12" class="w-full border border-gray-300 rounded p-2 text-sm" />
          </div>

          <div class="col-span-2 md:col-span-3 flex justify-end mt-2">
            <button type="submit" class="bg-[var(--color-primary)] text-black font-bold px-6 py-2 rounded hover:bg-yellow-400 transition">
              Guardar Pelea
            </button>
          </div>
        </form>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-6 border-b border-gray-100">
          <h3 class="text-lg font-bold text-gray-800">Historial de Peleas ({boxer.data.bouts.length})</h3>
        </div>
        
        {boxer.data.bouts.length === 0 ? (
          <div class="p-8 text-center text-gray-500">Aún no hay peleas registradas para este boxeador.</div>
        ) : (
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 text-gray-500 uppercase">
              <tr>
                <th class="px-6 py-3">Fecha</th>
                <th class="px-6 py-3">Oponente</th>
                <th class="px-6 py-3">Resultado</th>
                <th class="px-6 py-3">Lugar</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {boxer.data.bouts.slice().reverse().map((bout: any) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4">{new Date(bout.date).toLocaleDateString()}</td>
                  <td class="px-6 py-4 font-semibold">{bout.opponent}</td>
                  <td class="px-6 py-4">
                    <span class={`font-bold ${bout.result === 'W' ? 'text-green-600' : bout.result === 'L' ? 'text-red-600' : 'text-gray-500'}`}>
                      {bout.result}
                    </span>
                    <span class="text-gray-500 ml-1">({bout.method} - R{bout.rounds})</span>
                  </td>
                  <td class="px-6 py-4 text-gray-600">{bout.location || '-'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

    </div>
  </div>
</AdminLayout>
