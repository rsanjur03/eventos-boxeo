---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-[var(--bg-light)] py-12 px-4">
    <div class="max-w-6xl mx-auto">
      
      {/* Header */}
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-[var(--text-main)] uppercase tracking-tight mb-4">
          Próximos <span class="text-[var(--color-primary)]">Eventos</span>
        </h1>
        <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
          Adquiere tus boletos y sé parte de la historia del boxeo chiricano.
        </p>
      </div>

      {/* Events List */}
      <div class="space-y-8">
        
        {/* Single Event Card */}
        <div class="bg-[var(--bg-card)] shadow-xl rounded-2xl p-6 md:p-8 border-l-4 border-[var(--color-primary)] flex flex-col md:flex-row gap-8 items-center">
          
          <div class="flex-1">
            <div class="flex items-center gap-4 mb-3">
              <span class="bg-[var(--color-primary)] text-white px-3 py-1 rounded text-sm font-bold uppercase tracking-wider animate-pulse">
                Activo
              </span>
              <span class="text-[var(--color-gold)] font-bold text-lg">
                15 de Noviembre, 2026
              </span>
            </div>
            
            <h2 class="text-3xl font-black text-[var(--text-main)] uppercase mb-2">
              Noche de Campeones: STRYD
            </h2>
            <p class="text-[var(--text-muted)] text-lg mb-4">
              📍 Arena Roberto Durán, Chiriquí
            </p>
            
            <div class="border-t border-gray-200 pt-4 mt-4">
              <h3 class="text-[var(--text-main)] font-bold mb-2">Cartelera Principal:</h3>
              <ul class="text-[var(--text-muted)] space-y-1">
                <li>🥊 Luis Concepcion vs. Kenneth Llover (Supermosca)</li>
                <li>🥊 Javier García vs. Juan Perez (Ligero)</li>
              </ul>
            </div>
          </div>

          {/* Action Column */}
          <div class="w-full md:w-auto bg-[var(--bg-light)] p-6 rounded-xl border border-gray-200 text-center min-w-[250px]">
            <p class="text-[var(--text-muted)] mb-2 uppercase text-sm font-bold">Desde</p>
            <p class="text-4xl font-black text-[var(--text-main)] mb-6">$15.00</p>
            
            <button class="w-full bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-bold py-4 px-6 rounded uppercase tracking-wider transition-colors duration-300">
              Comprar Boletos
            </button>
            <p class="text-xs text-[var(--text-muted)] mt-4">
              Pagos procesados de forma segura vía Yappy
            </p>
          </div>

        </div>

      </div>

    </div>
  </main>
</Layout>
