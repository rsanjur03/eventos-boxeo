---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

let boxer: any = null;
try {
  const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
  const res = await fetch(`${apiUrl}/api/content?collection=boxer`);
  if (res.ok) {
    const data = await res.json();
    const boxerData = (data.data || []).find((b: any) => b.slug === id);
    if (boxerData) {
      boxer = {
        name: boxerData.data.title,
        alias: boxerData.data.alias || 'Sin Apodo',
        division: boxerData.data.weight || 'Peso Libre',
        idNum: boxerData.id.split('-')[1] || boxerData.id.slice(0,6),
        birthName: boxerData.data.title,
        sex: 'Masculino', 
        age: boxerData.data.dob ? new Date().getFullYear() - new Date(boxerData.data.dob).getFullYear() : 'N/A',
        nationality: boxerData.data.nationality || 'Panamá',
        stance: boxerData.data.stance || 'Orthodox',
        height: boxerData.data.height || 'N/A',
        reach: 'N/A',
        residence: boxerData.data.residence || 'Panamá',
        birthPlace: boxerData.data.birthPlace || 'Panamá',
        bouts: (boxerData.data.wins || 0) + (boxerData.data.losses || 0) + (boxerData.data.draws || 0),
        rounds: 0,
        koPercentage: (boxerData.data.wins || 0) > 0 ? Math.round(((boxerData.data.kos || 0) / ((boxerData.data.wins || 0) + (boxerData.data.losses || 0) + (boxerData.data.draws || 0))) * 100) + '%' : '0%',
        career: 'Activo',
        debut: 'N/A',
        stats: { 
          wins: boxerData.data.wins || 0, 
          losses: boxerData.data.losses || 0, 
          draws: boxerData.data.draws || 0, 
          kos: boxerData.data.kos || 0 
        },
        imageUrl: boxerData.data.imageUrl ? `${apiUrl}${boxerData.data.imageUrl}` : 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=400&auto=format&fit=crop',
        fights: []
      };
    }
  }
} catch (error) {
  console.error('Error fetching boxer:', error);
}

// Fallback just in case the database is completely empty during development or wrong ID
if (!boxer) {
  boxer = {
    name: 'Luis Concepcion',
    alias: 'El Nica',
    division: 'Supermosca',
    idNum: '352728',
    birthName: 'Luis Miguel Concepcion Montiel',
    sex: 'Masculino',
    age: 40,
    nationality: 'Panamá',
    stance: 'Orthodox',
    height: '5\' 2" / 157cm',
    reach: '63" / 160cm',
    residence: 'Panama City, Panamá',
    birthPlace: 'Panama City, Panamá',
    bouts: 52,
    rounds: 316,
    koPercentage: '72.5%',
    career: '2006-2025',
    debut: '2006-03-21',
    stats: { wins: 40, losses: 12, draws: 0, kos: 29 },
    imageUrl: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=400&auto=format&fit=crop',
    fights: [
      { date: 'Aug 2025', opponent: 'Kenneth Llover', oppRecord: '14-0-0', result: 'L', venue: 'Winford Resort, Manila' },
      { date: 'Oct 2023', opponent: 'David Cuellar', oppRecord: '25-0-0', result: 'L', venue: 'Poliforum, Cancun' },
      { date: 'Jun 2022', opponent: 'Juan Lopez', oppRecord: '15-9-1', result: 'W', venue: 'Coliseo de Combates, Panama City' },
    ]
  };
}
---

<Layout>
  <main class="min-h-screen bg-[var(--bg-light)] py-12 px-4">
    <div class="max-w-6xl mx-auto">
      
      {/* Header */}
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-black text-[var(--text-main)] uppercase tracking-tight">
          <span class="text-[var(--color-primary)]">#{boxer.idNum}</span> {boxer.name}
        </h1>
        <p class="text-[var(--color-gold)] font-bold text-xl uppercase mt-2">box-pro</p>
        <div class="h-1 w-full max-w-2xl mx-auto bg-gray-200 mt-4 relative">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-1 bg-red-600"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        
        {/* Left Column: Image & Score */}
        <div class="md:col-span-4">
          {/* Score Header */}
          <div class="flex text-center text-white font-black text-3xl mb-1">
            <div class="flex-1 bg-green-700 py-2 rounded-tl-lg">{boxer.stats.wins}</div>
            <div class="flex-1 bg-red-700 py-2">{boxer.stats.losses}</div>
            <div class="flex-1 bg-blue-500 py-2 rounded-tr-lg">{boxer.stats.draws}</div>
          </div>
          <div class="flex text-center text-xs font-bold uppercase mb-4">
            <div class="flex-1 text-green-500">{boxer.stats.kos} KOs</div>
            <div class="flex-1 text-red-500"></div>
            <div class="flex-1 text-blue-500"></div>
          </div>

          <div class="rounded-xl overflow-hidden bg-white shadow-lg border border-gray-100 p-2">
            <img src={boxer.imageUrl} alt={boxer.name} class="w-full h-auto rounded-lg grayscale" />
          </div>
        </div>

        {/* Right Column: Details */}
        <div class="md:col-span-8 bg-white shadow-lg border border-gray-100 rounded-2xl p-6 md:p-10">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm md:text-base">
            
            {/* Column 1 */}
            <div class="space-y-3">
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">division</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.division}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">bouts</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.bouts}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">rounds</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.rounds}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">KOs</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.koPercentage}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">career</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.career}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">debut</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.debut}</span>
              </div>
            </div>

            {/* Column 2 */}
            <div class="space-y-3">
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--color-primary)] font-semibold">ID#</span>
                <span class="w-2/3 text-[var(--color-primary)]">{boxer.idNum}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">birth name</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.birthName}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">alias</span>
                <span class="w-2/3 text-[var(--text-main)]">"{boxer.alias}"</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">age</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.age}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">nationality</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.nationality}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">stance</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.stance}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">height</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.height}</span>
              </div>
              <div class="flex border-b border-gray-100 pb-2">
                <span class="w-1/3 text-[var(--text-muted)] font-semibold">reach</span>
                <span class="w-2/3 text-[var(--text-main)]">{boxer.reach}</span>
              </div>
            </div>

          </div>
        </div>
      </div>

      {/* Fight History Table */}
      <div class="mt-16">
        <h3 class="text-2xl font-bold text-center text-[var(--text-main)] mb-6 uppercase">Pro Boxing {boxer.bouts} Bouts</h3>
        <div class="overflow-x-auto bg-white shadow-xl rounded-xl">
          <table class="w-full text-left text-sm text-[var(--text-main)]">
            <thead class="bg-gray-100 uppercase text-[var(--text-muted)]">
              <tr>
                <th class="px-4 py-3 rounded-tl-lg">Date</th>
                <th class="px-4 py-3">Opponent</th>
                <th class="px-4 py-3">W-L-D</th>
                <th class="px-4 py-3 text-center">Result</th>
                <th class="px-4 py-3 rounded-tr-lg">Venue</th>
              </tr>
            </thead>
            <tbody>
              {boxer.fights.map((fight, idx) => (
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-4">{fight.date}</td>
                  <td class="px-4 py-4 font-bold">{fight.opponent}</td>
                  <td class="px-4 py-4 text-[var(--text-muted)]">{fight.oppRecord}</td>
                  <td class="px-4 py-4 text-center">
                    <span class={`inline-block text-white px-3 py-1 font-bold rounded ${fight.result === 'W' ? 'bg-green-700' : 'bg-red-700'}`}>
                      {fight.result}
                    </span>
                  </td>
                  <td class="px-4 py-4 text-[var(--text-muted)]">{fight.venue}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</Layout>
