---
import Layout from '../../layouts/Layout.astro';

// This will fetch from SonicJS backend in production
const boxers = [
  {
    id: 'luis-concepcion',
    title: 'Luis Concepcion',
    alias: 'El Nica',
    weightClass: 'Supermosca',
    nationality: 'Panamá',
    imageUrl: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=400&auto=format&fit=crop', // Fallback image
    record: '40-12-0 (29 KOs)'
  },
  {
    id: 'javier-garcia',
    title: 'Javier García',
    alias: 'El Toro',
    weightClass: 'Ligero',
    nationality: 'México',
    imageUrl: 'https://images.unsplash.com/photo-1517466787929-bc90951d0974?q=80&w=400&auto=format&fit=crop',
    record: '27-0-2 (15 KOs)'
  }
];
---

<Layout>
  <main className="min-h-screen bg-[var(--bg-dark)] py-12 px-4">
    <div className="max-w-7xl mx-auto">
      
      {/* Header */}
      <div className="text-center mb-16">
        <h1 className="text-4xl md:text-5xl font-black text-white uppercase tracking-tight mb-4">
          Roster de <span className="text-[var(--color-primary)]">Boxeadores</span>
        </h1>
        <p className="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
          Conoce a los guerreros que dejan todo en el ring. Base de datos oficial de la COMIBOX Chiriquí.
        </p>
      </div>

      {/* Boxers Grid */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {boxers.map((boxer) => (
          <a href={`/boxeadores/${boxer.id}`} className="group block relative rounded-2xl overflow-hidden glassmorphism hover:border-[var(--color-primary)] transition-all duration-300">
            {/* Image Section */}
            <div className="aspect-[3/4] relative">
              <div className="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10"></div>
              <img 
                src={boxer.imageUrl} 
                alt={boxer.title} 
                className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 grayscale group-hover:grayscale-0"
              />
              
              {/* Overlay Content */}
              <div className="absolute bottom-0 left-0 w-full p-6 z-20">
                <p className="text-[var(--color-primary)] font-bold text-sm uppercase tracking-widest mb-1">
                  {boxer.weightClass}
                </p>
                <h2 className="text-2xl font-black text-white uppercase leading-none mb-1">
                  {boxer.title}
                </h2>
                <p className="text-white/70 italic mb-3">"{boxer.alias}"</p>
                
                <div className="flex justify-between items-center text-sm border-t border-white/20 pt-3">
                  <span className="text-white font-medium">{boxer.nationality}</span>
                  <span className="text-[var(--color-gold)] font-bold">{boxer.record}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>
