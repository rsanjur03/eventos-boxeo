---
import Layout from '../../layouts/Layout.astro';

let boxers = [];
try {
  const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
  const res = await fetch(`${apiUrl}/api/content?collection=boxer`);
  if (res.ok) {
    const data = await res.json();
    boxers = (data.data || []).map((item: any) => {
      const wins = item.data.wins || 0;
      const losses = item.data.losses || 0;
      const draws = item.data.draws || 0;
      const kos = item.data.kos || 0;

      return {
        id: item.slug,
        title: item.data.title,
        alias: item.data.alias || 'Sin Apodo',
        weightClass: item.data.weight || 'Peso Libre', // Fallback for now
        nationality: item.data.nationality || 'Panamá',
        imageUrl: item.data.imageUrl ? `${apiUrl}${item.data.imageUrl}` : 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=400&auto=format&fit=crop',
        record: `${wins}-${losses}-${draws} (${kos} KOs)`
      };
    });
  }
} catch (error) {
  console.error('Error connecting to SonicJS:', error);
}

// Fallback for development if DB is empty
if (boxers.length === 0) {
  boxers = [
    {
      id: 'luis-concepcion',
      title: 'Luis Concepcion',
      alias: 'El Nica',
      weightClass: 'Supermosca',
      nationality: 'Panamá',
      imageUrl: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?q=80&w=400&auto=format&fit=crop',
      record: '40-12-0 (29 KOs)'
    }
  ];
}
---

<Layout>
  <main class="min-h-screen bg-[var(--bg-light)] py-12 px-4">
    <div class="max-w-7xl mx-auto">
      
      {/* Header */}
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-[var(--text-main)] uppercase tracking-tight mb-4">
          Roster de <span class="text-[var(--color-primary)]">Boxeadores</span>
        </h1>
        <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
          Conoce a los guerreros que dejan todo en el ring. Base de datos oficial de la COMIBOX Chiriquí.
        </p>
      </div>

      {/* Boxers Grid */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {boxers.map((boxer) => (
          <a href={`/boxeadores/${boxer.id}`} class="group block relative rounded-2xl overflow-hidden bg-[var(--bg-card)] shadow-[0_4px_20px_rgba(0,0,0,0.05)] hover:border-[var(--color-primary)] transition-all duration-300">
            {/* Image Section */}
            <div class="aspect-[3/4] relative">
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10"></div>
              <img 
                src={boxer.imageUrl} 
                alt={boxer.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 grayscale group-hover:grayscale-0"
              />
              
              {/* Overlay Content */}
              <div class="absolute bottom-0 left-0 w-full p-6 z-20">
                <p class="text-[var(--color-primary)] font-bold text-sm uppercase tracking-widest mb-1">
                  {boxer.weightClass}
                </p>
                <h2 class="text-2xl font-black text-white uppercase leading-none mb-1">
                  {boxer.title}
                </h2>
                <p class="text-white/70 italic mb-3">"{boxer.alias}"</p>
                
                <div class="flex justify-between items-center text-sm border-t border-white/20 pt-3">
                  <span class="text-white font-medium">{boxer.nationality}</span>
                  <span class="text-[var(--color-gold)] font-bold">{boxer.record}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>
