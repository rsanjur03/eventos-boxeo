---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-[var(--bg-light)] py-12 px-4">
    <div class="max-w-4xl mx-auto">
      
      <div class="text-center mb-12">
        <h1 class="text-4xl font-black text-[var(--text-main)] uppercase tracking-tight mb-4">
          Portal de <span class="text-[var(--color-primary)]">Promotores</span>
        </h1>
        <p class="text-[var(--text-muted)]">
          Solicita la aprobación de la COMIBOX para tu próximo evento, gestiona documentos y sube requisitos (exámenes, contratos).
        </p>
      </div>

      <div class="bg-[var(--bg-card)] shadow-xl rounded-2xl p-8 border-t-4 border-[var(--color-primary)]">
        <h2 class="text-2xl font-bold text-[var(--text-main)] mb-6 uppercase">Solicitud de Nuevo Evento</h2>
        
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            {/* Promotor Info */}
            <div class="space-y-4">
              <h3 class="text-[var(--color-gold)] font-semibold uppercase text-sm tracking-wider">Datos del Organizador</h3>
              <div>
                <label class="block text-[var(--text-muted)] text-sm mb-1">Nombre / Empresa</label>
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-3 text-[var(--text-main)] focus:outline-none focus:border-[var(--color-primary)]" placeholder="Ej. STRYD Panama" />
              </div>
              <div>
                <label class="block text-[var(--text-muted)] text-sm mb-1">Correo Electrónico</label>
                <input type="email" class="w-full bg-white border border-gray-300 rounded p-3 text-[var(--text-main)] focus:outline-none focus:border-[var(--color-primary)]" placeholder="promotor@ejemplo.com" />
              </div>
            </div>

            {/* Event Info */}
            <div class="space-y-4">
              <h3 class="text-[var(--color-gold)] font-semibold uppercase text-sm tracking-wider">Datos del Evento</h3>
              <div>
                <label class="block text-[var(--text-muted)] text-sm mb-1">Nombre del Evento</label>
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-3 text-[var(--text-main)] focus:outline-none focus:border-[var(--color-primary)]" placeholder="Noche de Campeones" />
              </div>
              <div>
                <label class="block text-[var(--text-muted)] text-sm mb-1">Lugar / Arena</label>
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-3 text-[var(--text-main)] focus:outline-none focus:border-[var(--color-primary)]" placeholder="Arena Roberto Durán" />
              </div>
              <div>
                <label class="block text-[var(--text-muted)] text-sm mb-1">Fecha Propuesta</label>
                <input type="date" class="w-full bg-white border border-gray-300 rounded p-3 text-[var(--text-main)] focus:outline-none focus:border-[var(--color-primary)]" />
              </div>
            </div>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-[var(--color-gold)] font-semibold uppercase text-sm tracking-wider mb-4">Cartelera Principal (Peleas Propuestas)</h3>
            
            <div class="bg-gray-50 p-4 rounded border border-gray-200 mb-4">
              <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr_1fr_auto] gap-4 items-center">
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-2 text-[var(--text-main)] text-sm" placeholder="Boxeador A (Si existe, autocompleta)" />
                <span class="text-[var(--text-main)] font-bold text-center">VS</span>
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-2 text-[var(--text-main)] text-sm" placeholder="Boxeador B" />
                <input type="text" class="w-full bg-white border border-gray-300 rounded p-2 text-[var(--text-main)] text-sm" placeholder="Peso Pactado" />
                <input type="number" class="w-20 bg-white border border-gray-300 rounded p-2 text-[var(--text-main)] text-sm" placeholder="Rounds" />
              </div>
            </div>
            
            <button type="button" class="text-[var(--color-primary)] text-sm hover:underline font-bold">+ Agregar Pelea</button>
          </div>

          <div class="bg-blue-50 border border-blue-200 p-4 rounded text-blue-800 text-sm leading-relaxed mt-6">
            <p><strong>Nota:</strong> Al enviar esta solicitud, la COMIBOX revisará los detalles y generará una cotización de los costos oficiales de la comisión. Podrás descargar la cotización en PDF y acceder a un portal para subir los contratos, exámenes médicos y fotografías de los peleadores.</p>
          </div>

          <button type="submit" class="w-full bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-bold py-4 px-6 rounded uppercase tracking-wider transition-colors duration-300 mt-6">
            Enviar Solicitud de Evento
          </button>
        </form>

      </div>
    </div>
  </main>
</Layout>
