---
import Layout from '../layouts/Layout.astro';

// Fetch officials
let officials = [];
try {
  const apiUrl = import.meta.env.SONICJS_API_URL || 'https://api.comiboxchiriqui.com';
  const res = await fetch(`${apiUrl}/api/content?collection=official`);
  if (res.ok) {
    const data = await res.json();
    officials = data.data || [];
  }
} catch (error) {
  console.error('Error fetching officials:', error);
}

// Helper to calculate age
const getAge = (dobString: string) => {
  if (!dobString) return '-';
  const birthDate = new Date(dobString);
  const today = new Date();
  let age = today.getFullYear() - birthDate.getFullYear();
  const m = today.getMonth() - birthDate.getMonth();
  if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
    age--;
  }
  return age;
};

// Helper to format roles
const getRolesStr = (official: any) => {
  const roles = [];
  if (official.data.isReferee) roles.push('Árbitro');
  if (official.data.isJudge) roles.push('Juez');
  if (official.data.isTimekeeper) roles.push('Juez de Tiempo');
  return roles.join(', ') || 'Sin rol asignado';
};
---

<Layout>
  <main>
    {/* Header Section */}
    <div class="bg-black text-white pt-24 pb-16 relative overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-20 bg-[url('https://images.unsplash.com/photo-1599586120429-48281b6f0ece?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center"></div>
      <div class="max-w-7xl mx-auto px-4 relative z-10 text-center">
        <h1 class="text-4xl md:text-5xl font-black mb-4 uppercase tracking-tight text-[var(--color-gold)]">Oficiales (Jueces y Árbitros)</h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto font-light">
          El equipo encargado de garantizar el cumplimiento de las reglas y la integridad del boxeo en Chiriquí.
        </p>
      </div>
    </div>

    {/* Oficiales List */}
    <div class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4">
        
        {officials.length === 0 ? (
          <div class="text-center py-20 bg-white rounded-xl shadow-sm border border-gray-100">
            <span class="text-5xl mb-4 block">⚖️</span>
            <h3 class="text-xl font-bold text-gray-800 mb-2">No hay oficiales registrados</h3>
            <p class="text-gray-500">Pronto publicaremos la lista de nuestros jueces y árbitros.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {officials.map((o: any) => (
              <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:-translate-y-1 transition-transform duration-300">
                <div class="aspect-square bg-gray-200 relative overflow-hidden">
                  {o.data.imageUrl ? (
                    <img src={o.data.imageUrl} alt={o.data.title} class="w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full flex flex-col items-center justify-center text-gray-400">
                      <span class="text-6xl mb-2">⚖️</span>
                      <span class="text-xs font-bold uppercase tracking-widest">Sin foto</span>
                    </div>
                  )}
                  <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/80 to-transparent p-4 pt-12">
                    <p class="text-[var(--color-gold)] font-bold text-sm uppercase tracking-wider">{getRolesStr(o)}</p>
                  </div>
                </div>
                
                <div class="p-6">
                  <h3 class="text-xl font-black text-gray-900 mb-1">{o.data.title}</h3>
                  <div class="flex items-center text-sm text-gray-500 mt-2">
                    <span class="font-semibold text-gray-700 w-16">Edad:</span>
                    <span>{getAge(o.data.dob)} años</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
        
      </div>
    </div>
  </main>
</Layout>
