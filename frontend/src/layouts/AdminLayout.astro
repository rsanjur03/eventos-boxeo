---
import '../styles/global.css';
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="COMIBOX Admin Portal" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Admin COMIBOX</title>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-gray-900 text-white min-h-screen">
        <div class="p-6">
          <h2 class="text-2xl font-black text-[var(--color-primary)]">COMIBOX</h2>
          <p class="text-sm text-gray-400">Panel Administrativo</p>
        </div>
        <nav class="mt-6 px-4 space-y-2">
          <a href="/admin" class="block px-4 py-3 rounded-lg hover:bg-gray-800 transition">📊 Dashboard</a>
          <a href="/admin/carteleras" class="block px-4 py-3 rounded-lg hover:bg-gray-800 transition">🥊 Carteleras (Peleas)</a>
          <a href="/admin/taquilla" class="block px-4 py-3 rounded-lg hover:bg-gray-800 transition">🎟️ Taquilla & Libretas</a>
          <a href="/admin/contabilidad" class="block px-4 py-3 rounded-lg hover:bg-gray-800 transition">💰 Contabilidad</a>
          <hr class="border-gray-700 my-4" />
          <a href="/" class="block px-4 py-3 rounded-lg hover:bg-gray-800 transition text-gray-400">⬅️ Volver a la Web</a>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-8">
        <header class="flex justify-between items-center mb-8 bg-white p-4 rounded-xl shadow-sm">
          <h1 class="text-2xl font-bold text-gray-800">{title}</h1>
          <div class="flex items-center gap-4">
            <span class="text-sm font-semibold text-gray-600">Admin</span>
            <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center font-bold text-gray-500">A</div>
            <form method="POST" action="/admin/logout">
              <button type="submit" class="text-xs text-red-600 hover:underline font-bold">Cerrar Sesión</button>
            </form>
          </div>
        </header>

        <slot />
      </main>
    </div>
  </body>
</html>

