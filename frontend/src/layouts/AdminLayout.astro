---
import '../styles/global.css';
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} - COMIBOX Admin</title>
    <style>
      :root {
        --color-primary: #e63946; /* Rojo */
        --color-secondary: #2a9d8f; /* Verde */
        --color-sidebar: #1b4332; /* Verde Oscuro */
      }
      body {
        background-color: #f8f9fa; /* Blanco/Gris claro */
      }
    </style>
  </head>
  <body class="font-sans antialiased text-gray-900 flex h-screen overflow-hidden">
    
    {/* Sidebar */}
    <aside class="w-64 flex-shrink-0 flex flex-col justify-between" style="background-color: var(--color-sidebar); color: white;">
      <div>
        <div class="p-6">
          <a href="/" class="flex items-center space-x-3 mb-2 hover:opacity-80 transition cursor-pointer">
            <img src="/logo.png" alt="COMIBOXCH" class="w-12 h-12 object-contain bg-white rounded-full p-1" onerror="this.src='data:image/svg+xml;base64,'" />
            <div>
              <h1 class="text-xl font-black tracking-tight leading-tight" style="color: var(--color-primary);">
                COMIBOX
              </h1>
              <h2 class="text-sm font-bold tracking-widest text-white uppercase">
                Chiriquí
              </h2>
            </div>
          </a>
          <p class="text-xs text-gray-300 font-medium">Panel Administrativo</p>
        </div>
        
        <nav class="mt-6 px-4 space-y-2">
          <a href="/admin" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">📊 Dashboard</a>
          <a href="/admin/carteleras" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">🥊 Carteleras (Peleas)</a>
          <a href="/admin/boxeadores" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">🥊 Boxeadores</a>
          <a href="/admin/oficiales" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">⚖️ Jueces y Árbitros</a>
          <a href="/admin/taquilla" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">🎟️ Taquilla & Libretas</a>
          <a href="/admin/contabilidad" class="block px-4 py-3 rounded-lg hover:bg-green-800 transition">💰 Contabilidad</a>
          <hr class="border-green-800 my-4" />
          <a href="/" class="block px-4 py-3 rounded-lg text-blue-300 hover:bg-green-800 transition">⬅️ Volver a la Web</a>
        </nav>
      </div>
    </aside>

    {/* Main Content */}
    <main class="flex-1 flex flex-col h-screen overflow-y-auto">
      <header class="bg-white border-b border-gray-200 px-8 py-4 flex justify-between items-center sticky top-0 z-10">
        <h2 class="text-2xl font-bold text-gray-800">{title}</h2>
        <div class="flex items-center space-x-4">
          <span class="text-sm font-semibold text-gray-600">Admin</span>
          <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center font-bold text-gray-600">
            A
          </div>
          <form method="POST" action="/admin/logout">
            <button type="submit" class="text-sm text-[var(--color-primary)] font-bold hover:underline">Cerrar Sesión</button>
          </form>
        </div>
      </header>
      
      <div class="p-8 max-w-7xl mx-auto w-full">
        <slot />
      </div>
    </main>

  </body>
</html>
